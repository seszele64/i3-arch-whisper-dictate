# ============================================
# Whisper API Configuration
# ============================================
# Set WHISPER_PROVIDER to choose your provider: openai, groq, together, local, custom
# Then set the corresponding API key env var (or use WHISPER_API_KEY to override)

WHISPER_PROVIDER=openai
WHISPER_API_KEY=
WHISPER_BASE_URL=
WHISPER_MODEL=whisper-1
WHISPER_TIMEOUT=30
WHISPER_LANGUAGE=
WHISPER_TEMPERATURE=0

# ============================================
# Provider-specific API Keys (fallback)
# ============================================
# These are used automatically based on WHISPER_PROVIDER
# Only set the one matching your provider (or use WHISPER_API_KEY to override all)

OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# ============================================
# Provider Examples (uncomment ONE section)
# ============================================

# --- OpenAI ---
# WHISPER_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-...
# WHISPER_MODEL=whisper-1

# --- Groq ---
# WHISPER_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# WHISPER_MODEL=whisper-large-v3

# --- Together AI ---
# WHISPER_PROVIDER=together
# TOGETHER_API_KEY=...
# WHISPER_MODEL=whisper-1

# --- Local whisper.cpp / faster-whisper-server ---
# WHISPER_PROVIDER=local
# WHISPER_BASE_URL=http://localhost:8000/v1
# WHISPER_MODEL=base.en

# --- Custom OpenAI-compatible endpoint ---
# WHISPER_PROVIDER=custom
# WHISPER_API_KEY=sk-...
# WHISPER_BASE_URL=https://your-api.example.com/v1
# WHISPER_MODEL=whisper-1

# ============================================
# Audio Configuration
# ============================================
# These are currently code defaults; add env var support if needed in the future
# (No audio env vars are currently read by the application)

# ============================================
# Other
# ============================================
# XDG data directory override (default: ~/.local/share)
# XDG_DATA_HOME=

# Log level (default: INFO)
# LOG_LEVEL=INFO
